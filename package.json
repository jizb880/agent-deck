{
  "name": "agent-deck",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Local dashboard to manage multiple Claude Code + OpenCode CLI sessions (PTY, personas, split panes)",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev:server": "npm --prefix server run dev",
